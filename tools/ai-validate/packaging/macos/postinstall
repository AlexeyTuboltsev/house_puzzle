#!/bin/bash
# packaging/macos/postinstall — runs as part of the .pkg install.
#
# pkgbuild stages our bundled .jsx into /tmp/ai-validate-staging/. We
# locate every installed Adobe Illustrator and copy the file into each
# one's Scripts folder so it shows up under File > Scripts. Multi-version
# coexistence (2022 + 2024 side-by-side) is intentionally supported.
#
# Logs to /tmp/ai-validate-postinstall.log AND stderr (which macOS
# captures into /var/log/install.log under the matching pkg-install
# entry) so a silent "no install happened" failure can be diagnosed
# afterwards.

set -euo pipefail

LOG=/tmp/ai-validate-postinstall.log
exec > >(tee -a "$LOG") 2>&1
echo "===== postinstall $(date -u +%FT%TZ) ====="

STAGING="/tmp/ai-validate-staging"
BUNDLE="$STAGING/ai-validate.jsx"

if [[ ! -f "$BUNDLE" ]]; then
    echo "[postinstall] bundle missing at $BUNDLE — aborting"
    exit 1
fi
echo "[postinstall] bundle: $BUNDLE ($(wc -c < "$BUNDLE") bytes)"

shopt -s nullglob
TARGETS=(/Applications/Adobe\ Illustrator*)
if [[ ${#TARGETS[@]} -eq 0 ]]; then
    # No /Applications hit — try mdfind as a fallback (handles
    # custom install locations).
    while IFS= read -r app; do
        TARGETS+=("$app")
    done < <(mdfind 'kMDItemCFBundleIdentifier == "com.adobe.illustrator"' 2>/dev/null)
fi
echo "[postinstall] candidate Illustrator targets: ${TARGETS[*]:-(none)}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
    osascript -e 'display dialog "No Adobe Illustrator install was detected. ai-validate.jsx is at /tmp/ai-validate-staging/ai-validate.jsx — drop it into Illustrator'\''s Scripts folder manually." buttons {"OK"} default button 1' || true
    exit 0
fi

# macOS Illustrator's Scripts folder lives at <app>/Presets.localized/en_US/Scripts.
# (NOT inside the .app bundle — the directory above /Adobe Illustrator.app
# is the artist-facing root and holds Presets.localized, Plug-ins.localized,
# Cool Extras.localized, etc.) Try the .localized variant first; fall back
# to plain Presets/ for older or stripped builds.
INSTALLED_COUNT=0
for app in "${TARGETS[@]}"; do
    scripts_dir=""
    for candidate in \
        "$app/Presets.localized/en_US/Scripts" \
        "$app/Presets/en_US/Scripts"; do
        if [[ -d "$candidate" ]]; then
            scripts_dir="$candidate"
            break
        fi
    done
    if [[ -z "$scripts_dir" ]]; then
        echo "[postinstall] no Scripts folder under $app — skipped"
        continue
    fi
    cp "$BUNDLE" "$scripts_dir/ai-validate.jsx"
    chmod 644 "$scripts_dir/ai-validate.jsx"
    echo "[postinstall] installed → $scripts_dir/ai-validate.jsx"
    INSTALLED_COUNT=$((INSTALLED_COUNT + 1))
done

if [[ $INSTALLED_COUNT -eq 0 ]]; then
    # Detected Illustrator but couldn't find a Scripts folder under any.
    # Don't fail the install — just surface the issue so the artist knows.
    osascript -e 'display dialog "ai-validate: detected Adobe Illustrator but could not find its Scripts folder. The bundle is at /tmp/ai-validate-staging/ai-validate.jsx — drop it into File > Scripts > Other Script... manually. See /tmp/ai-validate-postinstall.log for details." buttons {"OK"} default button 1' || true
    # Keep staging so the artist can still grab the file.
    exit 0
fi

# Best-effort: prime the update-check cache so the script can warn
# about future versions without itself having to do a background HTTPS
# refresh (Illustrator ExtendScript on macOS has no silent shell-out
# path — File.execute on .scpt opens Script Editor, on .sh opens
# Terminal). Populating it here means the cache is at least as fresh
# as the most recent install.
#
# Postinstall runs as root for system-installed pkgs, so we have to
# write to the LOGGED-IN user's Application Support, not root's. Pull
# that user from the console-owner trick that's standard on macOS.
LOGGED_IN_USER=$(stat -f %Su /dev/console 2>/dev/null || true)
if [[ -n "$LOGGED_IN_USER" && "$LOGGED_IN_USER" != "root" ]]; then
    USER_HOME=$(dscl . -read "/Users/$LOGGED_IN_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
    if [[ -n "$USER_HOME" ]]; then
        CACHE_DIR="$USER_HOME/Library/Application Support/ai-validate"
        mkdir -p "$CACHE_DIR" || true
        if curl -fsSL --max-time 5 \
            -o "$CACHE_DIR/script-version-cache.json" \
            "https://raw.githubusercontent.com/AlexeyTuboltsev/house_puzzle/main/tools/ai-validate/script-version.json"
        then
            chown "$LOGGED_IN_USER" "$CACHE_DIR" "$CACHE_DIR/script-version-cache.json" || true
            echo "[postinstall] primed update cache at $CACHE_DIR/script-version-cache.json"
        else
            echo "[postinstall] update cache prime skipped (offline or fetch failed)"
        fi
    fi
fi

# Clean staging on success.
rm -rf "$STAGING"
echo "[postinstall] done — $INSTALLED_COUNT install(s)"
exit 0
