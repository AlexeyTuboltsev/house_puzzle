{
  "productName": "House Puzzle",
  "version": "0.1.0",
  "identifier": "com.house-puzzle.app",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [
      {
        "title": "House Puzzle Editor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AlexeyTuboltsev/house_puzzle/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
